{
  "embeds": [
    {
      "title": "{{.Website | json}}",
      "color": 3447003,
      "fields": [
        {
          "name": "Reviewer",
          "value": "{{if .Reviewer}}{{.Reviewer | json}}{{else}}N/A{{end}}",
          "inline": true
        },
        {
          "name": "User Rating",
          "value": "{{if .Reviewer}}⭐ {{.Rating}} / 5{{else}}N/A{{end}}",
          "inline": true
        },
        {
          "name": "Overall Rating",
          "value": "{{if .Reviewer}}⭐ {{.TotalRating}} / 5{{else}}N/A{{end}}",
          "inline": true
        },
        {
          "name": "Title",
          "value": "{{if .Reviewer}}{{.Title | json}}{{else}}N/A{{end}}",
          "inline": true
        },
        {
          "name": "Review Date",
          "value": "{{if .Reviewer}}<t:{{.UnixTimestamp}}:F>\n<t:{{.UnixTimestamp}}:R>{{else}}N/A{{end}}",
          "inline": true
        },
        {
          "name": "Content",
          "value": "{{if .Reviewer}}{{.Content | json}}{{else}}N/A{{end}}",
          "inline": false
        },
        {
          "name": "Review URL",
          "value": "{{if .Reviewer}}{{.ReviewURL}}{{else}}N/A{{end}}",
          "inline": false
        }
      ],
      "footer": {
        "text": "Good Riddance"
      },
      "timestamp": "{{.NowISO}}"
    }
  ]
}

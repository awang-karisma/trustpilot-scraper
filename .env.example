# Trustpilot URL(s) to scrape
# Single URL: TRUSTPILOT_URL=https://www.trustpilot.com/review/example.com
# Multiple URLs (semicolon-separated): TRUSTPILOT_URL=https://www.trustpilot.com/review/example1.com;https://www.trustpilot.com/review/example2.com
# With custom schedule (pipe-separated): TRUSTPILOT_URL=https://www.trustpilot.com/review/example.com|0 * * * *;https://www.trustpilot.com/review/test.com|*/30 * * * *
# Default schedule: hourly (0 * * * *)
TRUSTPILOT_URL=https://www.trustpilot.com/review/www.apple.com

# Default schedule for scraping (cron expression)
# Default: 0 * * * * (hourly)
# Examples:
#   */30 * * * *  - Every 30 minutes
#   0 * * * *     - Every hour
#   0 0 * * *     - Every day at midnight
#   0 9 * * 1-5   - Every weekday at 9 AM
DEFAULT_SCHEDULE=0 * * * *

# Migration Configuration
# WARNING: Setting this to true will DROP ALL TABLES on startup
# This will delete all existing data including reviews, ratings, and jobs
# Only enable for fresh deployments or when you want to reset the database
# Default: false (safety first - will not drop tables)
DROP_TABLES_ON_START=false

# Database URL
# Postgres: postgres://user:password@localhost:5432/dbname?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/trustpilot?sslmode=disable

# Template Configuration
# Directory containing notification template files (e.g., discord.json, slack.json)
TEMPLATE_DIR=/app/templates

# Chrome/Rod Configuration (for Go Rod scraping)
CHROME_BROWSER_PATH=                    # Path to local Chrome binary (optional)
CHROME_REMOTE_URL=ws://localhost:9222   # Remote Chrome WebSocket URL (optional, used if LAUNCHER_MANAGER_URL is empty)
CHROME_LAUNCHER_MANAGER_URL=ws://localhost:7317 # Go-rod launcher manager URL (optional, enables managed browser instances per worker)
CHROME_HEADLESS=true                    # Run browser in headless mode (true/false)
CHROME_WINDOW_WIDTH=1920                # Browser window width
CHROME_WINDOW_HEIGHT=1080               # Browser window height
CHROME_PAGE_LOAD_TIMEOUT=30             # Page load timeout in seconds
CHROME_RETRY_ATTEMPTS=3                 # Number of retry attempts
CHROME_RETRY_DELAY=2                    # Delay between retries in seconds
CHROME_USER_AGENT=Mozilla/5.0           # Custom user agent
CHROME_DISABLE_IMAGES=true              # Disable images for faster scraping
CHROME_DISABLE_JAVASCRIPT=false         # Disable JavaScript execution

# Worker Pool Configuration
WORKER_COUNT=3                          # Number of worker goroutines processing scrape jobs (default: 3)
QUEUE_SIZE=100                          # Maximum size of the job queue (default: 100)
SCRAPE_TIMEOUT=120                      # Timeout for scrape jobs in seconds (default: 120)
MAX_RETRIES=3                           # Maximum retry attempts for failed jobs (default: 3)
RETRY_BACKOFF=5                         # Delay between retries in seconds (default: 5)
MAX_PARALLEL_PAGES=50                   # Maximum number of pages that can be scraped in parallel per website (default: 50)

